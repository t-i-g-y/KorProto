    \u0438\u043D\u0438\u0446\u0438\u0430\u043B\u044B \"\u0414&\u042D\". \u0413\u043E\u0432\u043E\u0440\u044F\u0442,
    \u0447\u0442\u043E \u0432\u043E \u0432\u0440\u0435\u043C\u044F \u0412\u0435\u043B\u0438\u043A\u043E\u0433\u043E
    \u0411\u0435\u0434\u0441\u0442\u0432\u0438\u044F \u0438\u043C\u0435\u043D\u043D\u043E
    \u044D\u0442\u043E\u0439 \u043A\u0438\u0440\u043A\u043E\u0439 \u0440\u0430\u0441\u0447\u0438\u0449\u0430\u043B\u0438
    \u0437\u0430\u0432\u0430\u043B\u044B \u043D\u0430 \u0441\u0435\u0432\u0435\u0440\u043E-\u0432\u043E\u0441\u0442\u043E\u043A\u0435,
    \u043F\u044B\u0442\u0430\u044F\u0441\u044C \u044D\u0432\u0430\u043A\u0443\u0438\u0440\u043E\u0432\u0430\u0442\u044C
