  title: "\u041A\u0438\u0440\u043A\u0430 \u043F\u0443\u0442\u0435\u0439\u0446\u0430"
  story: "\u0421\u0442\u0430\u0440\u0430\u044F \u0436\u0435\u043B\u0435\u0437\u043D\u043E\u0434\u043E\u0440\u043E\u0436\u043D\u0430\u044F
    \u043A\u0438\u0440\u043A\u0430 \u043F\u043E\u043A\u0440\u044B\u0442\u0430 \u0440\u0436\u0430\u0432\u0447\u0438\u043D\u043E\u0439
    \u0438 \u0433\u0440\u044F\u0437\u044C\u044E. \u041D\u0430 \u0434\u0435\u0440\u0435\u0432\u044F\u043D\u043D\u043E\u0439
