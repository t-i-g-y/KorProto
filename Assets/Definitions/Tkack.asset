  title: "\u0421\u0442\u0430\u043D\u0446\u0438\u044F \u0441\u043E \u0441\u043B\u043E\u0436\u043D\u044B\u043C
    \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u043E\u043C!"
  description: "\u0412\u044B \u043F\u043E\u0441\u0442\u0440\u043E\u0438\u043B\u0438
    \u043F\u0443\u0442\u044C \u0432 \u0433\u043E\u0440\u043E\u0434 \u0422\u043A\u0430\u0446\u043A,
    \u043D\u043E \u0436\u0438\u0442\u0435\u043B\u0438 \u0445\u043E\u0442\u044F\u0442,
    \u0447\u0442\u043E\u0431\u044B \u0412\u044B \u0437\u0430\u043F\u043B\u0430\u0442\u0438\u043B\u0438
    \u043F\u0435\u0440\u0432\u043E\u043D\u0430\u0447\u0430\u043B\u044C\u043D\u044B\u0439
    \u0432\u0437\u043D\u043E\u0441 25 \u043A\u043E\u0440\u043A\u0440\u0435\u0434\u0438\u0442\u043E\u0432.
    \u0415\u0441\u043B\u0438 \u043E\u0442\u043A\u0430\u0436\u0435\u0442\u0435\u0441\u044C,
    \u0442\u043E \u043F\u0443\u0442\u044C \u0434\u043E \u0422\u043A\u0430\u0446\u043A\u0430
    \u043F\u0440\u0438\u0434\u0435\u0442\u0441\u044F \u0443\u0434\u0430\u043B\u0438\u0442\u044C!"
